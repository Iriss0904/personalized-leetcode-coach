    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "tsx scripts/dev-webui.ts",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
