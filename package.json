    "setup:piston": "tsx scripts/setup-piston.ts",
    "doctor": "tsx scripts/doctor.ts",
    "coach:smoke": "tsx scripts/coach-smoke.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma db execute --file prisma/migrations/0001_public_baseline/migration.sql",
    "db:seed": "tsx prisma/seed.ts",
    "db:init": "tsx scripts/init-database.ts",
    "fts:rebuild": "tsx scripts/rebuild-fts-index.ts",
    "piston:up": "docker compose -f piston/docker-compose.yml up -d",
    "piston:down": "docker compose -f piston/docker-compose.yml down",
    "piston:logs": "docker compose -f piston/docker-compose.yml logs -f",
    "piston:install": "tsx scripts/install-piston-runtimes.ts",
    "piston:smoke": "tsx scripts/piston-smoke.ts",
    "piston:boundary-smoke": "tsx scripts/piston-boundary-smoke.ts",
    "verify:hot150:piston": "tsx scripts/verify-hot150-piston.ts",
    "audit:hot150": "tsx scripts/generate-hot150-public-audit.ts",
    "validate:hot150": "tsx scripts/validate-hot150-public.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:smoke": "vitest run tests/unit",
    "test:e2e": "tsx scripts/test-e2e.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
